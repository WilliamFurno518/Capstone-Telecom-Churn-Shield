# ChurnShield - environment configuration template
# Copy this file to `.env` and fill in the values you want.
# The product works without these (heuristic fallback), but the LLM
# auto-mapping is noticeably smarter when a key is provided.

# --- LLM auto-mapping (optional) ----------------------------------------
# Any OpenAI-compatible chat endpoint works.
# Leave empty to force heuristic-only mapping.
CHURNSHIELD_LLM_API_KEY=
CHURNSHIELD_LLM_MODEL=gpt-4o-mini
CHURNSHIELD_LLM_BASE_URL=https://api.openai.com/v1

# Hard switch: set to "false" to disable LLM calls even if a key is present.
CHURNSHIELD_ENABLE_LLM_MAPPING=true
